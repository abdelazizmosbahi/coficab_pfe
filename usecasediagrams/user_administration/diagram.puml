@startuml
!theme plain

skinparam backgroundColor #FEFEFE
skinparam useCaseFontColor #1A1A2E
skinparam useCaseFontSize 12
skinparam useCaseBorderColor #2C3E50
skinparam useCaseBackgroundColor #FFFFFF
skinparam actorFontColor #1A1A2E
skinparam actorFontSize 14
skinparam actorFontStyle bold
skinparam arrowColor #34495E
skinparam arrowThickness 2
skinparam arrowFontSize 11
skinparam defaultTextAlignment center
skinparam linetype ortho
skinparam packageBackgroundColor #F4F6F9
skinparam packageBorderColor #2C3E50
skinparam packageFontColor #2C3E50
skinparam packageFontSize 13
skinparam packageFontStyle bold

left to right direction
title Cable Manufacturing AI\nUser Administration — Low-Level Use Case Decomposition

actor "Analyst" as analyst

rectangle "Top-Level\n(Actor-Facing)" as toplevel #E8F0FE {
  usecase (UCU1\nView All Users) as UCU1
  usecase (UCU2\nView Pending\nRegistrations) as UCU2
  usecase (UCU3\nManage Page\nPermissions) as UCU3
  usecase (UCU4\nManage Account\nStatus) as UCU4
}

rectangle "Low-Level\n(System Internals)" as lowlevel #F0F8F0 {
  usecase (UCAUTH\nAuthenticate) as UCAUTH
  usecase (UCU5\nQuery All Users) as UCU5
  usecase (UCU6\nQuery Pending\nOperators) as UCU6
  usecase (UCU7\nApprove Operator) as UCU7
  usecase (UCU8\nDecline Operator) as UCU8
  usecase (UCU9\nLoad Permissions\nfrom DB) as UCU9
  usecase (UCU10\nSave Permissions\nto DB) as UCU10
  usecase (UCU11\nToggle Active\nStatus) as UCU11
  usecase (UCU12\nDelete Account\nPermanently) as UCU12
}

' ── Actor connections ──
analyst --> UCU1
analyst --> UCU2
analyst --> UCU3
analyst --> UCU4

' ── Include: mandatory ──
' Prerequisite: every top-level UC requires authentication
UCU1 ..> UCAUTH : <<include>>
UCU2 ..> UCAUTH : <<include>>
UCU3 ..> UCAUTH : <<include>>
UCU4 ..> UCAUTH : <<include>>

UCU1 ..> UCU5 : <<include>>
UCU1 ..> UCU9 : <<include>>

UCU2 ..> UCU6 : <<include>>

UCU3 ..> UCU9 : <<include>>
UCU3 ..> UCU10 : <<include>>

' ── Extend: conditional ──
UCU7 ..> UCU2 : <<extend>>\nconditional\n(click Approve)
UCU8 ..> UCU2 : <<extend>>\nconditional\n(click Decline)

UCU11 ..> UCU4 : <<extend>>\nconditional\n(click Activate\n/ Disable)
UCU12 ..> UCU4 : <<extend>>\nconditional\n(click Delete)

@enduml
