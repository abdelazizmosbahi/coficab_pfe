@startuml
!theme plain

skinparam backgroundColor #FEFEFE
skinparam useCaseFontColor #1A1A2E
skinparam useCaseFontSize 12
skinparam useCaseBorderColor #2C3E50
skinparam useCaseBackgroundColor #FFFFFF
skinparam actorFontColor #1A1A2E
skinparam actorFontSize 14
skinparam actorFontStyle bold
skinparam arrowColor #34495E
skinparam arrowThickness 2
skinparam arrowFontSize 11
skinparam defaultTextAlignment center
skinparam linetype ortho
skinparam packageBackgroundColor #F4F6F9
skinparam packageBorderColor #2C3E50
skinparam packageFontColor #2C3E50
skinparam packageFontSize 13
skinparam packageFontStyle bold

left to right direction
title Cable Manufacturing AI\nAuthentication — Low-Level Use Case Decomposition

actor "Analyst" as analyst

rectangle "Top-Level\n(Actor-Facing)" as toplevel #E8F0FE {
  usecase (UCA1\nLog In) as UCA1
  usecase (UCA2\nLog Out) as UCA2
}

rectangle "Low-Level\n(System Internals)" as lowlevel #F0F8F0 {
  usecase (UCA3\nValidate\nCredentials) as UCA3
  usecase (UCA4\nBuild & Persist\nSession Token) as UCA4
  usecase (UCA5\nDestroy Session\nGlobally) as UCA5
  usecase (UCA6\nRestore Session\nFrom Storage) as UCA6
  usecase (UCA7\nReject\nAuthentication) as UCA7
}

' ── Actor connections ──
analyst --> UCA1
analyst --> UCA2

' ── Include: mandatory behavior ──
UCA1 ..> UCA3 : <<include>>\nmandatory
UCA1 ..> UCA4 : <<include>>\nmandatory

UCA2 ..> UCA5 : <<include>>\nmandatory

' ── Extend: conditional behavior ──
UCA6 ..> UCA1 : <<extend>>\nconditional\n(token in URL /\nlocalStorage)

UCA7 ..> UCA1 : <<extend>>\nconditional\n(wrong creds /\ndisabled account)

@enduml
