@startuml
!theme plain

skinparam backgroundColor #FEFEFE
skinparam useCaseFontColor #1A1A2E
skinparam useCaseFontSize 12
skinparam useCaseBorderColor #2C3E50
skinparam useCaseBackgroundColor #FFFFFF
skinparam actorFontColor #1A1A2E
skinparam actorFontSize 14
skinparam actorFontStyle bold
skinparam arrowColor #34495E
skinparam arrowThickness 2
skinparam arrowFontSize 11
skinparam defaultTextAlignment center
skinparam linetype ortho
skinparam packageBackgroundColor #F4F6F9
skinparam packageBorderColor #2C3E50
skinparam packageFontColor #2C3E50
skinparam packageFontSize 13
skinparam packageFontStyle bold

left to right direction
title Cable Manufacturing AI\nRoot Cause Analysis — Low-Level Use Case Decomposition

actor "Analyst" as analyst

rectangle "Top-Level\n(Actor-Facing)" as toplevel #E8F0FE {
  usecase (UCR1\nAnalyze Parameter\nRoot Cause) as UCR1
  usecase (UCR2\nAnalyze Quality\nDegradation) as UCR2
}

rectangle "Low-Level\n(System Internals)" as lowlevel #F0F8F0 {
  usecase (UCAUTH\nAuthenticate) as UCAUTH
  usecase (UCR3\nInvoke Mistral\nAI API) as UCR3
  usecase (UCR4\nConstruct Single-\nParam Prompt) as UCR4
  usecase (UCR5\nConstruct Aggregated\nPrompt) as UCR5
  usecase (UCR6\nRead API Key &\nInit Mistral SDK) as UCR6
  usecase (UCR7\nSend Chat\nCompletion Request) as UCR7
  usecase (UCR8\nParse &\nDisplay Response) as UCR8
}

' ── Actor connections ──
analyst --> UCR1
analyst --> UCR2

' ── Include: mandatory behavior ──
' Prerequisite: every top-level UC requires authentication
UCR1 ..> UCAUTH : <<include>>
UCR2 ..> UCAUTH : <<include>>

UCR1 ..> UCR3 : <<include>>
UCR1 ..> UCR4 : <<include>>

UCR2 ..> UCR3 : <<include>>
UCR2 ..> UCR5 : <<include>>

UCR3 ..> UCR6 : <<include>>
UCR3 ..> UCR7 : <<include>>
UCR3 ..> UCR8 : <<include>>

@enduml
