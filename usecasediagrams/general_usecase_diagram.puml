@startuml
!theme plain

skinparam backgroundColor #FEFEFE
skinparam packageBackgroundColor #F4F6F9
skinparam packageBorderColor #2C3E50
skinparam packageFontColor #2C3E50
skinparam packageFontSize 14
skinparam packageFontStyle bold
skinparam actorFontColor #1A1A2E
skinparam actorFontSize 14
skinparam actorFontStyle bold
skinparam useCaseFontColor #1A1A2E
skinparam useCaseFontSize 11
skinparam useCaseBorderColor #2C3E50
skinparam useCaseBackgroundColor #FFFFFF
skinparam arrowColor #34495E
skinparam arrowFontSize 10
skinparam arrowThickness 2
skinparam defaultTextAlignment center
skinparam linetype ortho

left to right direction
title "Cable Manufacturing AI — Analyst Use Case Diagram\n(click package names for detailed sub-diagrams)"

actor "Analyst" as analyst

rectangle "Authentication\nsub-diagram →" as auth_pkg #E8F0FE {
  usecase (UC01\nAuthenticate) as UC01
  usecase (UC02\nLogout) as UC02
  note bottom
    **3 low-level UCs:**
    Validate Credentials,
    Build Session,
    Destroy Session
    
    ←— All other UCs (UC03–UC18)
    <<include>> UC01
  end note
}

rectangle "Machine Configuration\nManagement\nsub-diagram →" as config_pkg #F0F8F0 {
  usecase (UC03\nView Machine\nStatus) as UC03
  usecase (UC04\nCreate\nConfiguration) as UC04
  usecase (UC05\nView\nConfigurations) as UC05
  usecase (UC06\nEdit\nConfiguration) as UC06
  usecase (UC07\nDelete\nConfiguration) as UC07
  note bottom
    **7 low-level UCs:**
    Browse Registry,
    Browse Catalog,
    Insert/Fetch/Update/
    Delete/ReadStatus
  end note
}

rectangle "Real-Time Monitoring\n& Quality Prediction\nsub-diagram →" as monitor_pkg #FFF8E8 {
  usecase (UC08\nExecute Config\nAnalysis) as UC08
  usecase (UC09\nView Reference\nDatasheet) as UC09
  usecase (UC10\nMonitor Real-Time\nParameters) as UC10
  usecase (UC11\nView Parameter\nTraceability) as UC11
  usecase (UC12\nAnalyze\nRoot Cause) as UC12
  note bottom
    **10 low-level UCs:**
    Launch Papermill,
    Extract/Store Results,
    Load Values, Compute
    Quality, Eval Spec,
    Sliding Window, Full
    History, Render Chart
  end note
}

rectangle "Recipe-Aware\nDatasheet Generation\nsub-diagram →" as datasheet_pkg #F5E8FF {
  usecase (UC13\nGenerate Recipe\nDatasheet) as UC13
  usecase (UC14\nView Analysis\nHistory) as UC14
  note bottom
    **12 low-level UCs:**
    6 wizard steps + 6
    system internals
    (Query/Calculate/Save
    /Load/List/Details)
  end note
}

rectangle "User Administration\nsub-diagram →" as admin_pkg #FFE8E8 {
  usecase (UC15\nView Pending\nRegistrations) as UC15
  usecase (UC16\nManage Page\nPermissions) as UC16
  usecase (UC17\nManage Account\nStatus) as UC17
  usecase (UC18\nView All Users) as UC18
  note bottom
    **8 low-level UCs:**
    Query/Approve/Decline
    Load/Save Permissions
    Toggle Active/Delete
  end note
}

' ── Actor connections ──
analyst --> UC01
analyst --> UC02
analyst --> UC03
analyst --> UC04
analyst --> UC05
analyst --> UC06
analyst --> UC07
analyst --> UC08
analyst --> UC09
analyst --> UC10
analyst --> UC13
analyst --> UC14
analyst --> UC15
analyst --> UC16
analyst --> UC17
analyst --> UC18

' ── Authentication prerequisite for all non-auth use cases ──
UC03 ..> UC01 : <<include>>
UC04 ..> UC01 : <<include>>
UC05 ..> UC01 : <<include>>
UC06 ..> UC01 : <<include>>
UC07 ..> UC01 : <<include>>
UC08 ..> UC01 : <<include>>
UC09 ..> UC01 : <<include>>
UC10 ..> UC01 : <<include>>
UC11 ..> UC01 : <<include>>
UC12 ..> UC01 : <<include>>
UC13 ..> UC01 : <<include>>
UC14 ..> UC01 : <<include>>
UC15 ..> UC01 : <<include>>
UC16 ..> UC01 : <<include>>
UC17 ..> UC01 : <<include>>
UC18 ..> UC01 : <<include>>

' ── Extend relationships (conditional/optional) ──
UC11 ..> UC10 : <<extend>>\nconditional\n(click 📈 on param)
UC12 ..> UC10 : <<extend>>\nconditional\n(🔍 or quality<50%)

@enduml
